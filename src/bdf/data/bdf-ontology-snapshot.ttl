    rdfs:label "Step Energy / Wh"@en ;
    dcterms:isReplacedBy :step_cumulative_energy_wh ;
    qudt:hasQuantityKind quantitykind:Energy ;
    rdfs:comment "Running accumulation of energy throughput within the current test step, in watt hour: the time integral of the current-signed instantaneous power (P times the sign of I) from the step start, monotonically non-decreasing within the step and reset to zero at each step transition. The direction of transfer is indicated by step_type or the sign of current_ampere, not by this value."@en ;
