<https://w3id.org/battery-data-alliance/ontology/battery-data-format> a owl:Ontology ;
    dcterms:abstract "An application ontology for the Battery Data Format (BDF) from the Battery Data Alliance (BDA)" ;
    dcterms:created "2025-01-23"^^xsd:date ;
    dcterms:creator <https://orcid.org/0000-0002-8758-6109> ;
    dcterms:issued "2026-05-14"^^xsd:date ;
    dcterms:license <http://www.apache.org/licenses/LICENSE-2.0> ;
    dcterms:modified "2026-07-19"^^xsd:date ;
    dcterms:publisher <https://github.com/battery-data-alliance> ;
    dcterms:title "Battery Data Format Ontology"@en ;
    bibo:status "stable" ;
    vann:preferredNamespacePrefix "bdf" ;
    vann:preferredNamespaceUri "https://w3id.org/battery-data-alliance/ontology/battery-data-format#" ;
    owl:imports <https://w3id.org/emmo/domain/battery/0.18.6/battery> ;
    owl:priorVersion <https://w3id.org/battery-data-alliance/ontology/battery-data-format/1.2.0/battery-data-format> ;
    owl:versionIRI <https://w3id.org/battery-data-alliance/ontology/battery-data-format/1.3.0/battery-data-format> ;
    owl:versionInfo "1.3.0" .

:absolute_impedance_ohm a owl:Class ;
    rdfs:label "Absolute Impedance / ohm"@en ;
    qudt:hasQuantityKind quantitykind:Impedance ;
    rdfs:comment "The magnitude of the complex impedance, in ohm."@en ;
    rdfs:seeAlso unit:OHM ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:Ohm ],
        sosa:ObservableProperty,
        emmo:EMMO_79a02de5_b884_4eab_bc18_f67997d597a2 ;
    skos:altLabel "absolute_impedance_ohm"@en ;
    skos:definition "The magnitude of the complex impedance, in ohm."@en ;
    skos:notation "absolute_impedance_ohm"@en ;
    skos:prefLabel "Absolute Impedance / ohm"@en ;
    prov:wasDerivedFrom :imaginary_impedance_ohm,
        :real_impedance_ohm ;
    schema:description "The magnitude of the complex impedance, in ohm."@en ;
    schema:name "Absolute Impedance / ohm"@en ;
    schema:unitCode "Ohm" ;
    schema:unitText "ohm"@en ;
    :latexFormula "|Z| = \\sqrt{Z_\\mathrm{re}^2 + Z_\\mathrm{im}^2}"^^xsd:string ;
    :latexSymbol "|Z|"^^xsd:string ;
    :obligation "optional" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "The magnitude of the complex impedance, in ohm."@en .

:ac_internal_resistance_ohm a owl:Class ;
    rdfs:label "AC Internal Resistance / ohm"@en ;
    qudt:hasQuantityKind quantitykind:Resistance ;
    rdfs:comment "Alternating current internal resistance of the test object, in ohm: the magnitude of the impedance at a fixed excitation frequency, conventionally 1 kHz unless otherwise stated. Equivalent to the ACR quantity reported by some instruments (e.g. Arbin ACR). The excitation frequency should be recorded in accompanying metadata."@en ;
    rdfs:seeAlso unit:OHM ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:Ohm ],
        sosa:ObservableProperty,
        :internal_resistance_ohm ;
    skos:altLabel "ac_internal_resistance_ohm"@en,
        "ac_resistance_ohm"@en,
        "acr"@en ;
    skos:definition "Alternating current internal resistance of the test object, in ohm: the magnitude of the impedance at a fixed excitation frequency, conventionally 1 kHz unless otherwise stated. Equivalent to the ACR quantity reported by some instruments (e.g. Arbin ACR). The excitation frequency should be recorded in accompanying metadata."@en ;
    skos:notation "ac_internal_resistance_ohm" ;
    skos:prefLabel "AC Internal Resistance / ohm"@en ;
    schema:description "AC internal resistance: impedance magnitude at a fixed excitation frequency, conventionally 1 kHz. Equivalent to instrument ACR outputs."@en ;
    schema:name "AC Internal Resistance / ohm"@en ;
    schema:unitCode "Ohm" ;
    schema:unitText "ohm"@en ;
    :latexSymbol "R_\\mathrm{AC}"^^xsd:string ;
    :obligation "optional" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Alternating current internal resistance of the test object, in ohm: the magnitude of the impedance at a fixed excitation frequency, conventionally 1 kHz unless otherwise stated. Equivalent to the ACR quantity reported by some instruments (e.g. Arbin ACR). The excitation frequency should be recorded in accompanying metadata."@en .

:ambient_pressure_pa a owl:Class ;
    rdfs:label "Ambient Pressure / Pa"@en ;
    qudt:hasQuantityKind quantitykind:Pressure ;
    rdfs:comment "Ambient air pressure recorded during testing, in pascal."@en ;
    rdfs:seeAlso unit:PA ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:Pascal ],
        sosa:ObservableProperty,
        emmo:EMMO_50a44256_9dc5_434b_bad4_74a4d9a29989 ;
    skos:altLabel "ambient_pressure_pa"@en,
        "ambient_pressure_pascal"@en ;
    skos:definition "Ambient air pressure recorded during testing, in pascal."@en ;
    skos:notation "ambient_pressure_pa" ;
    skos:prefLabel "Ambient Pressure / Pa"@en ;
    schema:description "Ambient air pressure recorded during testing, in pascal."@en ;
    schema:name "Ambient Pressure / Pa"@en ;
    schema:unitCode "Pa" ;
    schema:unitText "pascal"@en ;
    :latexSymbol "p_\\mathrm{amb}"^^xsd:string ;
    :obligation "optional" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Ambient air pressure recorded during testing, in pascal."@en .

:ambient_temperature_celsius a owl:Class ;
    rdfs:label "Ambient Temperature / degC"@en ;
    qudt:hasQuantityKind quantitykind:Temperature ;
    rdfs:comment "Ambient temperature recorded during testing, in degree Celsius."@en ;
    rdfs:seeAlso unit:DEG_C ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:DegreeCelsius ],
        sosa:ObservableProperty,
        emmo:EMMO_66bc9029_f473_45ff_bab9_c3509ff37a22 ;
    skos:altLabel "ambient_temperature_celsius"@en,
        "ambient_temperature_degc"@en ;
    skos:definition "Ambient temperature recorded during testing, in degree Celsius."@en ;
    skos:notation "ambient_temperature_celsius" ;
    skos:prefLabel "Ambient Temperature / degC"@en ;
    schema:description "Ambient temperature recorded during testing, in degree Celsius."@en ;
    schema:name "Ambient Temperature / degC"@en ;
    schema:unitCode "Cel" ;
    schema:unitText "degree Celsius"@en ;
    :latexSymbol "T_\\mathrm{amb}"^^xsd:string ;
    :obligation "recommended" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Ambient temperature recorded during testing, in degree Celsius."@en .

:applied_pressure_pa a owl:Class ;
    rdfs:label "Applied Pressure / Pa"@en ;
    qudt:hasQuantityKind quantitykind:Pressure ;
    rdfs:comment "External pressure actively applied to the test object and controlled by an external agent (e.g. a fixture, clamp, or press), in pascal. Distinguished from surface_pressure_pa, which is the pressure measured at the surface of the test object regardless of its source."@en ;
    rdfs:seeAlso unit:PA ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:Pascal ],
        sosa:ObservableProperty,
        emmo:EMMO_50a44256_9dc5_434b_bad4_74a4d9a29989 ;
    skos:altLabel "applied_pressure_pa"@en,
        "applied_pressure_pascal"@en ;
    skos:definition "External pressure actively applied to the test object and controlled by an external agent (e.g. a fixture, clamp, or press), in pascal. Distinguished from surface_pressure_pa, which is the pressure measured at the surface of the test object regardless of its source."@en ;
    skos:notation "applied_pressure_pa" ;
    skos:prefLabel "Applied Pressure / Pa"@en ;
    schema:description "External pressure actively applied to the test object and controlled by an external agent (e.g. a fixture, clamp, or press), in pascal. Distinguished from surface_pressure_pa, which is the pressure measured at the surface of the test object regardless of its source."@en ;
    schema:name "Applied Pressure / Pa"@en ;
    schema:unitCode "Pa" ;
    schema:unitText "pascal"@en ;
    :latexSymbol "p_\\mathrm{app}"^^xsd:string ;
    :obligation "optional" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "External pressure actively applied to the test object and controlled by an external agent (e.g. a fixture, clamp, or press), in pascal. Distinguished from surface_pressure_pa, which is the pressure measured at the surface of the test object regardless of its source."@en .

:cumulative_capacity_ah a owl:Class ;
    rdfs:label "Cumulative Capacity / Ah"@en ;
    qudt:hasQuantityKind quantitykind:ElectricCharge ;
    rdfs:comment "Total Ah throughput since the start of the test, in ampere hour. Defined as charging_capacity_ah + discharging_capacity_ah; always monotonically non-decreasing. Counts charge flow in both directions and is therefore independent of the net state of charge."@en ;
    rdfs:seeAlso unit:A-HR ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:AmpereHour ],
        sosa:ObservableProperty,
        electrochemistry:electrochemistry_df9e9d49_12fa_4794_b482_e0dcd2a7bb66 ;
    skos:altLabel "cumulative_capacity_ah"@en,
        "cumulative_capacity_ampere_hour"@en ;
    skos:definition "Total Ah throughput since the start of the test, in ampere hour. Defined as charging_capacity_ah + discharging_capacity_ah; always monotonically non-decreasing. Counts charge flow in both directions and is therefore independent of the net state of charge."@en ;
    skos:notation "cumulative_capacity_ah" ;
    skos:prefLabel "Cumulative Capacity / Ah"@en ;
    skos:scopeNote "Suitable for throughput-based degradation models."@en ;
    prov:wasDerivedFrom :current_ampere,
        :test_time_second ;
    schema:description "Total Ah throughput since test start: charging_capacity_ah + discharging_capacity_ah. Always monotonically non-decreasing."@en ;
    schema:measurementTechnique "Running integral of the absolute value of current from test start (charge throughput). Always non-decreasing."@en ;
    schema:name "Cumulative Capacity / Ah"@en ;
    schema:unitCode "A.h" ;
    schema:unitText "ampere hour"@en ;
    :latexFormula "Q_\\mathrm{cum}(t) = Q_\\mathrm{chg}(t) + Q_\\mathrm{dchg}(t) = \\frac{1}{3600}\\int_0^t \\bigl|I(\\tau)\\bigr|\\,\\mathrm{d}\\tau"^^xsd:string ;
    :latexSymbol "Q_\\mathrm{cum}"^^xsd:string ;
    :obligation "optional" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Total Ah throughput since the start of the test, in ampere hour. Defined as charging_capacity_ah + discharging_capacity_ah; always monotonically non-decreasing. Counts charge flow in both directions and is therefore independent of the net state of charge."@en .

:cumulative_energy_wh a owl:Class ;
    rdfs:label "Cumulative Energy / Wh"@en ;
    qudt:hasQuantityKind quantitykind:Energy ;
    rdfs:comment "Total Wh throughput since the start of the test, in watt hour. Defined as charging_energy_wh + discharging_energy_wh; always monotonically non-decreasing."@en ;
    rdfs:seeAlso unit:W-HR ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:WattHour ],
        sosa:ObservableProperty,
        electrochemistry:electrochemistry_0f986d97_445f_4075_a5ce_ddde598a47a9 ;
    skos:altLabel "cumulative_energy_watt_hour"@en,
        "cumulative_energy_wh"@en ;
    skos:definition "Total Wh throughput since the start of the test, in watt hour. Defined as charging_energy_wh + discharging_energy_wh; always monotonically non-decreasing."@en ;
    skos:notation "cumulative_energy_wh" ;
    skos:prefLabel "Cumulative Energy / Wh"@en ;
    prov:wasDerivedFrom :power_watt,
        :test_time_second ;
    schema:description "Total Wh throughput since test start: charging_energy_wh + discharging_energy_wh. Always monotonically non-decreasing."@en ;
    schema:measurementTechnique "Running integral of the absolute value of power from test start (energy throughput). Always non-decreasing."@en ;
    schema:name "Cumulative Energy / Wh"@en ;
    schema:unitCode "W.h" ;
    schema:unitText "watt hour"@en ;
    :latexFormula "E_\\mathrm{cum}(t) = E_\\mathrm{chg}(t) + E_\\mathrm{dchg}(t) = \\frac{1}{3600}\\int_0^t P(\\tau)\\,\\operatorname{sgn} I(\\tau)\\,\\mathrm{d}\\tau"^^xsd:string ;
    :latexSymbol "E_\\mathrm{cum}"^^xsd:string ;
    :obligation "optional" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Total Wh throughput since the start of the test, in watt hour. Defined as charging_energy_wh + discharging_energy_wh; always monotonically non-decreasing."@en .

:cycle_cumulative_capacity_ah a owl:Class ;
    rdfs:label "Cycle Cumulative Capacity / Ah"@en ;
    qudt:hasQuantityKind quantitykind:ElectricCharge ;
    rdfs:comment "Running accumulation of charge throughput within the current cycle, in ampere hour: the time integral of the absolute current from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_capacity_ah + cycle_discharging_capacity_ah."@en ;
    rdfs:seeAlso unit:A-HR ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:AmpereHour ],
        sosa:ObservableProperty,
        electrochemistry:electrochemistry_ae108db7_8765_4329_9908_059277dee586 ;
    skos:altLabel "cycle_cumulative_capacity_ah"@en,
        "cycle_cumulative_capacity_ampere_hour"@en ;
    skos:definition "Running accumulation of charge throughput within the current cycle, in ampere hour: the time integral of the absolute current from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_capacity_ah + cycle_discharging_capacity_ah."@en ;
    skos:notation "cycle_cumulative_capacity_ah" ;
    skos:prefLabel "Cycle Cumulative Capacity / Ah"@en ;
    prov:wasDerivedFrom :current_ampere,
        :cycle_count ;
    schema:description "Running accumulation of charge throughput within the current cycle, in ampere hour. Monotonically non-decreasing within the cycle; resets to zero when cycle_count increments."@en ;
    schema:measurementTechnique "Time integral of the absolute value of current from the start of the current cycle."@en ;
    schema:name "Cycle Cumulative Capacity / Ah"@en ;
    schema:unitCode "A.h" ;
    schema:unitText "ampere hour"@en ;
    :latexFormula "Q_\\mathrm{cum}^\\mathrm{cyc}(t) = Q_\\mathrm{chg}^\\mathrm{cyc}(t) + Q_\\mathrm{dchg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} \\bigl|I(\\tau)\\bigr|\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle}"^^xsd:string ;
    :latexSymbol "Q_\\mathrm{cum}^\\mathrm{cyc}"^^xsd:string ;
    :obligation "optional" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Running accumulation of charge throughput within the current cycle, in ampere hour: the time integral of the absolute current from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_capacity_ah + cycle_discharging_capacity_ah."@en .

:cycle_cumulative_energy_wh a owl:Class ;
    rdfs:label "Cycle Cumulative Energy / Wh"@en ;
    qudt:hasQuantityKind quantitykind:Energy ;
    rdfs:comment "Running accumulation of energy throughput within the current cycle, in watt hour: the time integral of the current-signed instantaneous power (P times the sign of I) from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_energy_wh + cycle_discharging_energy_wh."@en ;
    rdfs:seeAlso unit:W-HR ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:WattHour ],
        sosa:ObservableProperty,
        electrochemistry:electrochemistry_46376e5d_9627_4514_9881_9e62083625c3 ;
    skos:altLabel "cycle_cumulative_energy_watt_hour"@en,
        "cycle_cumulative_energy_wh"@en ;
    skos:definition "Running accumulation of energy throughput within the current cycle, in watt hour: the time integral of the current-signed instantaneous power (P times the sign of I) from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_energy_wh + cycle_discharging_energy_wh."@en ;
    skos:notation "cycle_cumulative_energy_wh" ;
    skos:prefLabel "Cycle Cumulative Energy / Wh"@en ;
    prov:wasDerivedFrom :cycle_count,
        :power_watt ;
    schema:description "Running accumulation of energy throughput within the current cycle, in watt hour. Monotonically non-decreasing within the cycle; resets to zero when cycle_count increments."@en ;
    schema:measurementTechnique "Time integral of the current-signed instantaneous power from the start of the current cycle."@en ;
    schema:name "Cycle Cumulative Energy / Wh"@en ;
    schema:unitCode "W.h" ;
    schema:unitText "watt hour"@en ;
    :latexFormula "E_\\mathrm{cum}^\\mathrm{cyc}(t) = E_\\mathrm{chg}^\\mathrm{cyc}(t) + E_\\mathrm{dchg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} P(\\tau)\\,\\operatorname{sgn} I(\\tau)\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle}"^^xsd:string ;
    :latexSymbol "E_\\mathrm{cum}^\\mathrm{cyc}"^^xsd:string ;
    :obligation "optional" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Running accumulation of energy throughput within the current cycle, in watt hour: the time integral of the current-signed instantaneous power (P times the sign of I) from the start of the current cycle, monotonically non-decreasing within the cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Defined as cycle_charging_energy_wh + cycle_discharging_energy_wh."@en .

:cycle_net_capacity_ah a owl:Class ;
    rdfs:label "Cycle Net Capacity / Ah"@en ;
    qudt:hasQuantityKind quantitykind:ElectricCharge ;
    rdfs:comment "Net charge transferred during the current cycle, in ampere hour. Defined as cycle_charging_capacity_ah minus cycle_discharging_capacity_ah; the running signed integral of current from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more charge is extracted than injected during the cycle. Its end-of-cycle value is the per-cycle coulombic slippage: the irreversible charge consumed by side reactions during that cycle."@en ;
    rdfs:seeAlso unit:A-HR ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:AmpereHour ],
        sosa:ObservableProperty,
        electrochemistry:electrochemistry_791c1915_a791_4450_acd8_7f94764743b5 ;
    skos:altLabel "cycle_net_capacity_ah"@en,
        "cycle_net_capacity_ampere_hour"@en ;
    skos:definition "Net charge transferred during the current cycle, in ampere hour. Defined as cycle_charging_capacity_ah minus cycle_discharging_capacity_ah; the running signed integral of current from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more charge is extracted than injected during the cycle. Its end-of-cycle value is the per-cycle coulombic slippage: the irreversible charge consumed by side reactions during that cycle."@en ;
    skos:notation "cycle_net_capacity_ah" ;
    skos:prefLabel "Cycle Net Capacity / Ah"@en ;
    prov:wasDerivedFrom :cycle_charging_capacity_ah,
        :cycle_discharging_capacity_ah ;
    schema:description "Running net capacity within the current cycle: cycle_charging_capacity_ah - cycle_discharging_capacity_ah. Can be negative; resets to zero when cycle_count increments."@en ;
    schema:measurementTechnique "Running signed integral of current from the start of the current cycle."@en ;
    schema:name "Cycle Net Capacity / Ah"@en ;
    schema:unitCode "A.h" ;
    schema:unitText "ampere hour"@en ;
    :latexFormula "Q_\\mathrm{net}^\\mathrm{cyc}(t) = Q_\\mathrm{chg}^\\mathrm{cyc}(t) - Q_\\mathrm{dchg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} I(\\tau)\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle}"^^xsd:string ;
    :latexSymbol "Q_\\mathrm{net}^\\mathrm{cyc}"^^xsd:string ;
    :obligation "optional" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Net charge transferred during the current cycle, in ampere hour. Defined as cycle_charging_capacity_ah minus cycle_discharging_capacity_ah; the running signed integral of current from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more charge is extracted than injected during the cycle. Its end-of-cycle value is the per-cycle coulombic slippage: the irreversible charge consumed by side reactions during that cycle."@en .

:cycle_net_energy_wh a owl:Class ;
    rdfs:label "Cycle Net Energy / Wh"@en ;
    qudt:hasQuantityKind quantitykind:Energy ;
    rdfs:comment "Net energy transferred during the current cycle, in watt hour. Defined as cycle_charging_energy_wh minus cycle_discharging_energy_wh; the running signed integral of instantaneous power from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more energy is extracted than delivered during the cycle. Its end-of-cycle value is the net energy absorbed over that cycle, reflecting voltage hysteresis and other losses."@en ;
    rdfs:seeAlso unit:W-HR ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:WattHour ],
        sosa:ObservableProperty,
        electrochemistry:electrochemistry_46376e5d_9627_4514_9881_9e62083625c3 ;
    skos:altLabel "cycle_net_energy_watt_hour"@en,
        "cycle_net_energy_wh"@en ;
    skos:definition "Net energy transferred during the current cycle, in watt hour. Defined as cycle_charging_energy_wh minus cycle_discharging_energy_wh; the running signed integral of instantaneous power from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more energy is extracted than delivered during the cycle. Its end-of-cycle value is the net energy absorbed over that cycle, reflecting voltage hysteresis and other losses."@en ;
    skos:notation "cycle_net_energy_wh" ;
    skos:prefLabel "Cycle Net Energy / Wh"@en ;
    prov:wasDerivedFrom :cycle_charging_energy_wh,
        :cycle_discharging_energy_wh ;
    schema:description "Running net energy within the current cycle: cycle_charging_energy_wh - cycle_discharging_energy_wh. Can be negative; resets to zero when cycle_count increments."@en ;
    schema:measurementTechnique "Running signed integral of instantaneous power from the start of the current cycle."@en ;
    schema:name "Cycle Net Energy / Wh"@en ;
    schema:unitCode "W.h" ;
    schema:unitText "watt hour"@en ;
    :latexFormula "E_\\mathrm{net}^\\mathrm{cyc}(t) = E_\\mathrm{chg}^\\mathrm{cyc}(t) - E_\\mathrm{dchg}^\\mathrm{cyc}(t) = \\frac{1}{3600}\\int_{t_c}^{t} P(\\tau)\\,\\mathrm{d}\\tau,\\quad t_c = \\text{start of the current cycle}"^^xsd:string ;
    :latexSymbol "E_\\mathrm{net}^\\mathrm{cyc}"^^xsd:string ;
    :obligation "optional" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Net energy transferred during the current cycle, in watt hour. Defined as cycle_charging_energy_wh minus cycle_discharging_energy_wh; the running signed integral of instantaneous power from the start of the current cycle; resets to zero when cycle_count increments (cycle boundaries are instrument-defined; see cycle_count). Can be negative if more energy is extracted than delivered during the cycle. Its end-of-cycle value is the net energy absorbed over that cycle, reflecting voltage hysteresis and other losses."@en .

