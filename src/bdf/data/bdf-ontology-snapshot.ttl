:step_record_index a owl:Class ;
    rdfs:label "Step Record Index / 1"@en ;
    qudt:hasQuantityKind quantitykind:Count ;
    rdfs:comment "1-based positional counter for data points within a step. Resets to 1 at the start of each new step and increments by 1 for each subsequent recorded data point. Always derivable from the data; not typically exported directly by cycler software. This is the within-step data-point counter, not the program step identifier: an instrument column named 'Step Index' (e.g. Arbin Step_Index) maps to step_id, not to this property."@en ;
    rdfs:seeAlso unit:NUM ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:EMMO_5ebd5e01_0ed3_49a2_a30d_cd05cbe72978 ],
        sosa:ObservableProperty,
        emmo:EMMO_0cd58641_824c_4851_907f_f4c3be76630c ;
    skos:altLabel "step_index"@en,
        "step_record_index"@en,
        "step_record_index_1"@en ;
    skos:definition "1-based positional counter for data points within a step. Resets to 1 at the start of each new step and increments by 1 for each subsequent recorded data point. Always derivable from the data; not typically exported directly by cycler software. This is the within-step data-point counter, not the program step identifier: an instrument column named 'Step Index' (e.g. Arbin Step_Index) maps to step_id, not to this property."@en ;
    skos:historyNote "Introduced in 1.3.0 (2026-07-17) as the new name of step_index, which is deprecated and redirects here via dcterms:isReplacedBy; the concept is unchanged."@en ;
    skos:notation "step_record_index" ;
    skos:prefLabel "Step Record Index / 1"@en ;
    schema:description "1-based positional counter for data points within a step. Resets to 1 at the start of each new step and increments by 1 for each subsequent recorded data point. Always derivable from the data; not typically exported directly by cycler software. This is the within-step data-point counter, not the program step identifier: an instrument column named 'Step Index' (e.g. Arbin Step_Index) maps to step_id, not to this property."@en ;
    schema:name "Step Record Index / 1"@en ;
    schema:unitCode "1" ;
    schema:unitText "one"@en ;
    :latexSymbol "j"^^xsd:string ;
    :obligation "optional" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "1-based positional counter for data points within a step. Resets to 1 at the start of each new step and increments by 1 for each subsequent recorded data point. Always derivable from the data; not typically exported directly by cycler software. This is the within-step data-point counter, not the program step identifier: an instrument column named 'Step Index' (e.g. Arbin Step_Index) maps to step_id, not to this property."@en .

:unix_time_second a owl:Class ;
    rdfs:label "Unix Time / s"@en ;
    qudt:hasQuantityKind quantitykind:Time ;
    rdfs:comment "Timestamp expressed as Unix time, in second: seconds elapsed since 1970-01-01T00:00:00 UTC (the Unix epoch), excluding leap seconds. The value identifies an absolute instant and is independent of local time zone: the same physical moment has the same value everywhere, and local wall-clock times must be converted to UTC before encoding."@en ;
    rdfs:seeAlso unit:SEC ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty emmo:EMMO_bed1d005_b04e_4a90_94cf_02bc678a8569 ;
            owl:someValuesFrom emmo:Second ],
        sosa:ObservableProperty,
        electrochemistry:electrochemistry_27b3799c_250c_4332_8b71_7992c4a7bb05 ;
    skos:altLabel "unix_time_s"@en,
        "unix_time_second"@en ;
    skos:definition "Timestamp expressed as Unix time, in second: seconds elapsed since 1970-01-01T00:00:00 UTC (the Unix epoch), excluding leap seconds. The value identifies an absolute instant and is independent of local time zone: the same physical moment has the same value everywhere, and local wall-clock times must be converted to UTC before encoding."@en ;
    skos:notation "unix_time_second" ;
    skos:prefLabel "Unix Time / s"@en ;
    skos:scopeNote "A common conversion error is computing seconds since the epoch from a naive local wall-clock timestamp as if it were UTC, which shifts all values by the local UTC offset (including daylight-saving changes mid-test). Instruments that log local time must have their timestamps converted to UTC, not reinterpreted."@en ;
    schema:description "Timestamp expressed as Unix time, in second: seconds elapsed since 1970-01-01T00:00:00 UTC (the Unix epoch), excluding leap seconds. The value identifies an absolute instant and is independent of local time zone: the same physical moment has the same value everywhere, and local wall-clock times must be converted to UTC before encoding."@en ;
    schema:name "Unix Time / s"@en ;
    schema:unitCode "s" ;
    schema:unitText "second"@en ;
    :latexSymbol "t_\\mathrm{unix}"^^xsd:string ;
    :obligation "recommended" ;
    emmo:EMMO_967080e5_2f42_4eb2_a3a9_c58143e835f9 "Timestamp expressed as Unix time, in second: seconds elapsed since 1970-01-01T00:00:00 UTC (the Unix epoch), excluding leap seconds. The value identifies an absolute instant and is independent of local time zone: the same physical moment has the same value everywhere, and local wall-clock times must be converted to UTC before encoding."@en .

